generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Spike table — proves Prisma connects and migrates.
// Full schema will be designed incrementally as features are built.
model SolarSite {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
