{
  "version": 8,
  "name": "SolarLayout Dark (preview)",
  "metadata": {
    "solarlayout:theme": "dark",
    "solarlayout:purpose": "Overlay-only style. No basemap tiles (see ADR 0002). Draft colours from packages/ui/src/tokens.css ([data-theme=\"dark\"]); polish deferred to S13.5."
  },
  "sources": {
    "kmz-boundaries": {
      "type": "geojson",
      "data": { "type": "FeatureCollection", "features": [] }
    },
    "kmz-obstacles": {
      "type": "geojson",
      "data": { "type": "FeatureCollection", "features": [] }
    },
    "kmz-line-obstructions": {
      "type": "geojson",
      "data": { "type": "FeatureCollection", "features": [] }
    },
    "kmz-tables": {
      "type": "geojson",
      "data": { "type": "FeatureCollection", "features": [] }
    },
    "kmz-icrs": {
      "type": "geojson",
      "data": { "type": "FeatureCollection", "features": [] }
    },
    "kmz-string-inverters": {
      "type": "geojson",
      "data": { "type": "FeatureCollection", "features": [] }
    },
    "kmz-dc-cables": {
      "type": "geojson",
      "data": { "type": "FeatureCollection", "features": [] }
    },
    "kmz-ac-cables": {
      "type": "geojson",
      "data": { "type": "FeatureCollection", "features": [] }
    },
    "kmz-las": {
      "type": "geojson",
      "data": { "type": "FeatureCollection", "features": [] }
    },
    "kmz-la-circles": {
      "type": "geojson",
      "data": { "type": "FeatureCollection", "features": [] }
    }
  },
  "layers": [
    {
      "id": "canvas-background",
      "type": "background",
      "paint": {
        "background-color": "#17171a"
      }
    },
    {
      "id": "boundary-fill",
      "type": "fill",
      "source": "kmz-boundaries",
      "paint": {
        "fill-color": "rgba(236, 236, 234, 0.02)"
      }
    },
    {
      "id": "boundary-outline",
      "type": "line",
      "source": "kmz-boundaries",
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "rgba(236, 236, 234, 0.55)",
        "line-width": 1.5
      }
    },
    {
      "id": "obstacle-fill",
      "type": "fill",
      "source": "kmz-obstacles",
      "paint": {
        "fill-color": "rgba(236, 236, 234, 0.10)"
      }
    },
    {
      "id": "obstacle-outline",
      "type": "line",
      "source": "kmz-obstacles",
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "rgba(236, 236, 234, 0.32)",
        "line-width": 1
      }
    },
    {
      "id": "line-obstruction",
      "type": "line",
      "source": "kmz-line-obstructions",
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "rgba(255, 120, 120, 0.55)",
        "line-width": 2,
        "line-dasharray": [2, 1.5]
      }
    },
    {
      "id": "tables-fill",
      "type": "fill",
      "source": "kmz-tables",
      "paint": {
        "fill-color": "rgba(170, 190, 210, 0.22)"
      }
    },
    {
      "id": "tables-outline",
      "type": "line",
      "source": "kmz-tables",
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "rgba(170, 190, 210, 0.55)",
        "line-width": 0.5
      }
    },
    {
      "id": "icrs-fill",
      "type": "fill",
      "source": "kmz-icrs",
      "paint": {
        "fill-color": "rgba(220, 150, 80, 0.55)"
      }
    },
    {
      "id": "icrs-outline",
      "type": "line",
      "source": "kmz-icrs",
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "rgba(255, 180, 100, 0.9)",
        "line-width": 1
      }
    },
    {
      "id": "dc-cables",
      "type": "line",
      "source": "kmz-dc-cables",
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "rgba(140, 180, 230, 0.70)",
        "line-width": 0.8
      }
    },
    {
      "id": "ac-cables",
      "type": "line",
      "source": "kmz-ac-cables",
      "layout": {
        "visibility": "none",
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "rgba(255, 130, 100, 0.85)",
        "line-width": 1.2
      }
    },
    {
      "id": "string-inverters-fill",
      "type": "fill",
      "source": "kmz-string-inverters",
      "paint": {
        "fill-color": "rgba(180, 140, 240, 0.75)"
      }
    },
    {
      "id": "string-inverters-outline",
      "type": "line",
      "source": "kmz-string-inverters",
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "rgba(220, 180, 255, 0.95)",
        "line-width": 0.8
      }
    },
    {
      "id": "la-circles-fill",
      "type": "fill",
      "source": "kmz-la-circles",
      "layout": {
        "visibility": "none"
      },
      "paint": {
        "fill-color": "rgba(255, 140, 90, 0.12)"
      }
    },
    {
      "id": "la-circles-outline",
      "type": "line",
      "source": "kmz-la-circles",
      "layout": {
        "visibility": "none",
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "rgba(255, 120, 80, 0.35)",
        "line-width": 0.8
      }
    },
    {
      "id": "la-rects-fill",
      "type": "fill",
      "source": "kmz-las",
      "layout": {
        "visibility": "none"
      },
      "paint": {
        "fill-color": "rgba(255, 110, 90, 0.85)"
      }
    },
    {
      "id": "la-rects-outline",
      "type": "line",
      "source": "kmz-las",
      "layout": {
        "visibility": "none",
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "rgba(255, 170, 140, 0.95)",
        "line-width": 1
      }
    }
  ]
}
