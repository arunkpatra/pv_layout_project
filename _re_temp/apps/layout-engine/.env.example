# Layout Engine — local environment variables
# Copy this file to .env and fill in real values. Never commit .env.
#
# See docs/AWS_RESOURCES.md for full setup guidance.

# Postgres connection string (local Docker: see docker-compose.yml)
DATABASE_URL=postgresql://renewable:renewable@localhost:5432/renewable_energy

# S3 bucket for layout artifacts
# local    → renewable-energy-local-artifacts
# staging  → renewable-energy-staging-artifacts
# prod     → renewable-energy-prod-artifacts
S3_ARTIFACTS_BUCKET=renewable-energy-local-artifacts

# AWS credentials for the renewable-energy-app IAM user
# Get values from aws-creds/renewable-energy-app.env (gitignored)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# Optional: override the HTTP port (default 8000)
# PORT=8000
