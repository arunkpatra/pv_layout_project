generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model DownloadRegistration {
  id        String   @id @default("")
  name      String
  email     String
  mobile    String?
  product   String
  ipAddress String
  createdAt DateTime @default(now())

  @@map("download_registrations")
}
