# Desktop app environment variables.
#
# Copy this file to `.env.local` (gitignored) and edit values to match your
# local dev setup. Vite's `envPrefix` (see `vite.config.ts`) only exposes
# variables prefixed `VITE_` and `TAURI_ENV_` to the WebView, so don't put
# secrets here — anything `VITE_*` ends up in the bundle.
#
# Read at build time. Restart `bun run tauri dev` after editing.

# ---- API base URL --------------------------------------------------------
#
# Override the SolarLayout API base URL. Default if unset is the live
# production API at https://api.solarlayout.in.
#
# Local dev: point at the mvp_api Hono server in the renewable_energy repo.
# That repo's `apps/mvp_api/src/env.ts` defaults the port to 3003.
#
# Run the backend first:
#   cd /path/to/renewable_energy
#   bunx turbo dev --filter=@renewable-energy/api
#
# Then start the desktop dev shell:
#   cd /path/to/pv_layout_project/apps/desktop
#   bun run tauri dev
#
# VITE_SOLARLAYOUT_API_URL=http://localhost:3003
