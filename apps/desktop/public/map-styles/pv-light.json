{
  "version": 8,
  "name": "SolarLayout Light",
  "metadata": {
    "solarlayout:theme": "light",
    "solarlayout:purpose": "Overlay-only style. No basemap tiles (see ADR 0002). Colours mirror the canvas-vis tokens in packages/ui/src/tokens.css (:root)."
  },
  "sources": {
    "kmz-boundaries": {
      "type": "geojson",
      "data": { "type": "FeatureCollection", "features": [] }
    },
    "kmz-obstacles": {
      "type": "geojson",
      "data": { "type": "FeatureCollection", "features": [] }
    },
    "kmz-line-obstructions": {
      "type": "geojson",
      "data": { "type": "FeatureCollection", "features": [] }
    },
    "kmz-tables": {
      "type": "geojson",
      "data": { "type": "FeatureCollection", "features": [] }
    },
    "kmz-icrs": {
      "type": "geojson",
      "data": { "type": "FeatureCollection", "features": [] }
    },
    "kmz-string-inverters": {
      "type": "geojson",
      "data": { "type": "FeatureCollection", "features": [] }
    },
    "kmz-dc-cables": {
      "type": "geojson",
      "data": { "type": "FeatureCollection", "features": [] }
    },
    "kmz-ac-cables": {
      "type": "geojson",
      "data": { "type": "FeatureCollection", "features": [] }
    },
    "kmz-las": {
      "type": "geojson",
      "data": { "type": "FeatureCollection", "features": [] }
    },
    "kmz-la-circles": {
      "type": "geojson",
      "data": { "type": "FeatureCollection", "features": [] }
    }
  },
  "layers": [
    {
      "id": "canvas-background",
      "type": "background",
      "paint": {
        "background-color": "#f7f6f3"
      }
    },
    {
      "id": "boundary-fill",
      "type": "fill",
      "source": "kmz-boundaries",
      "paint": {
        "fill-color": "rgba(26, 26, 25, 0.02)"
      }
    },
    {
      "id": "boundary-outline",
      "type": "line",
      "source": "kmz-boundaries",
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "rgba(26, 26, 25, 0.55)",
        "line-width": 1.5
      }
    },
    {
      "id": "obstacle-fill",
      "type": "fill",
      "source": "kmz-obstacles",
      "paint": {
        "fill-color": "rgba(26, 26, 25, 0.12)"
      }
    },
    {
      "id": "obstacle-outline",
      "type": "line",
      "source": "kmz-obstacles",
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "rgba(26, 26, 25, 0.32)",
        "line-width": 1
      }
    },
    {
      "id": "line-obstruction",
      "type": "line",
      "source": "kmz-line-obstructions",
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "rgba(180, 44, 44, 0.45)",
        "line-width": 2,
        "line-dasharray": [2, 1.5]
      }
    },
    {
      "id": "tables-fill",
      "type": "fill",
      "source": "kmz-tables",
      "paint": {
        "fill-color": "rgba(70, 90, 110, 0.30)"
      }
    },
    {
      "id": "tables-outline",
      "type": "line",
      "source": "kmz-tables",
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "rgba(70, 90, 110, 0.65)",
        "line-width": 0.5
      }
    },
    {
      "id": "icrs-fill",
      "type": "fill",
      "source": "kmz-icrs",
      "paint": {
        "fill-color": "rgba(180, 110, 50, 0.55)"
      }
    },
    {
      "id": "icrs-outline",
      "type": "line",
      "source": "kmz-icrs",
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "rgba(120, 70, 30, 0.85)",
        "line-width": 1
      }
    },
    {
      "id": "dc-cables",
      "type": "line",
      "source": "kmz-dc-cables",
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "rgba(60, 80, 110, 0.70)",
        "line-width": 0.8
      }
    },
    {
      "id": "ac-cables",
      "type": "line",
      "source": "kmz-ac-cables",
      "layout": {
        "visibility": "none",
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "rgba(170, 60, 40, 0.80)",
        "line-width": 1.2
      }
    },
    {
      "id": "string-inverters-fill",
      "type": "fill",
      "source": "kmz-string-inverters",
      "paint": {
        "fill-color": "rgba(95, 50, 135, 0.75)"
      }
    },
    {
      "id": "string-inverters-outline",
      "type": "line",
      "source": "kmz-string-inverters",
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "rgba(60, 25, 95, 0.92)",
        "line-width": 0.8
      }
    },
    {
      "id": "la-circles-fill",
      "type": "fill",
      "source": "kmz-la-circles",
      "layout": {
        "visibility": "none"
      },
      "paint": {
        "fill-color": "rgba(205, 90, 50, 0.10)"
      }
    },
    {
      "id": "la-circles-outline",
      "type": "line",
      "source": "kmz-la-circles",
      "layout": {
        "visibility": "none",
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "rgba(180, 70, 40, 0.30)",
        "line-width": 0.8
      }
    },
    {
      "id": "la-rects-fill",
      "type": "fill",
      "source": "kmz-las",
      "layout": {
        "visibility": "none"
      },
      "paint": {
        "fill-color": "rgba(210, 60, 50, 0.85)"
      }
    },
    {
      "id": "la-rects-outline",
      "type": "line",
      "source": "kmz-las",
      "layout": {
        "visibility": "none",
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "rgba(140, 30, 30, 0.95)",
        "line-width": 1
      }
    }
  ]
}
