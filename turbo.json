{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "tsconfig.tsbuildinfo"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "outputs": ["coverage/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "@renewable-energy/db#typecheck": {
      "dependsOn": ["db:generate"],
      "outputs": []
    },
    "@renewable-energy/db#build": {
      "dependsOn": ["db:generate"],
      "outputs": ["dist/**", "tsconfig.tsbuildinfo"],
      "env": ["DATABASE_URL"]
    },
    "db:generate": {
      "inputs": ["prisma/**/*.prisma", "prisma.config.ts"],
      "outputs": ["node_modules/.prisma/**"],
      "cache": false
    },
    "db:validate": {
      "inputs": ["prisma/**/*.prisma", "prisma.config.ts"],
      "outputs": []
    },
    "db:status": {
      "dependsOn": ["db:generate"],
      "cache": false
    },
    "db:migrate": {
      "dependsOn": ["db:generate"],
      "cache": false
    },
    "db:seed": {
      "dependsOn": ["db:migrate"],
      "cache": false
    },
    "db:studio": {
      "dependsOn": ["db:generate"],
      "persistent": true,
      "cache": false
    },
    "@renewable-energy/api#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": ["DATABASE_URL", "PORT", "NODE_ENV", "CORS_ORIGINS"]
    },
    "@renewable-energy/api#typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
