{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "tsconfig.tsbuildinfo"],
      "env": [
        "DATABASE_URL",
        "CLERK_SECRET_KEY",
        "CORS_ORIGINS",
        "NODE_ENV",
        "PORT",
        "NODEJS_HELPERS",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_CLERK_SIGN_IN_URL",
        "NEXT_PUBLIC_CLERK_SIGN_UP_URL",
        "NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL",
        "NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL",
        "USE_LOCAL_ENV",
        "LAYOUT_ENGINE_URL",
        "SQS_LAYOUT_QUEUE_URL",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_REGION",
        "S3_ARTIFACTS_BUCKET",
        "NEXT_PUBLIC_MVP_API_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "outputs": ["coverage/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "@renewable-energy/db#typecheck": {
      "dependsOn": ["db:generate"],
      "outputs": []
    },
    "@renewable-energy/db#build": {
      "dependsOn": ["db:generate"],
      "outputs": ["dist/**", "tsconfig.tsbuildinfo"],
      "env": [
        "DATABASE_URL",
        "CLERK_SECRET_KEY",
        "CORS_ORIGINS",
        "NODE_ENV",
        "PORT",
        "NODEJS_HELPERS",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_CLERK_SIGN_IN_URL",
        "NEXT_PUBLIC_CLERK_SIGN_UP_URL",
        "NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL",
        "NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL",
        "SQS_LAYOUT_QUEUE_URL",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_REGION",
        "S3_ARTIFACTS_BUCKET"
      ]
    },
    "db:generate": {
      "inputs": ["prisma/**/*.prisma", "prisma.config.ts"],
      "outputs": ["node_modules/.prisma/**"],
      "cache": false
    },
    "db:validate": {
      "inputs": ["prisma/**/*.prisma", "prisma.config.ts"],
      "outputs": []
    },
    "db:status": {
      "dependsOn": ["db:generate"],
      "cache": false
    },
    "db:migrate": {
      "dependsOn": ["db:generate"],
      "cache": false
    },
    "db:seed": {
      "dependsOn": ["db:migrate"],
      "cache": false
    },
    "db:studio": {
      "dependsOn": ["db:generate"],
      "persistent": true,
      "cache": false
    },
    "@renewable-energy/api#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": [
        "DATABASE_URL",
        "CLERK_SECRET_KEY",
        "CORS_ORIGINS",
        "NODE_ENV",
        "PORT",
        "NODEJS_HELPERS",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_CLERK_SIGN_IN_URL",
        "NEXT_PUBLIC_CLERK_SIGN_UP_URL",
        "NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL",
        "NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL",
        "USE_LOCAL_ENV",
        "LAYOUT_ENGINE_URL",
        "SQS_LAYOUT_QUEUE_URL",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_REGION",
        "S3_ARTIFACTS_BUCKET"
      ]
    },
    "@renewable-energy/api#typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@renewable-energy/web#typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@renewable-energy/mvp-db#typecheck": {
      "dependsOn": ["mvp-db:generate"],
      "outputs": []
    },
    "@renewable-energy/mvp-db#build": {
      "dependsOn": ["mvp-db:generate"],
      "outputs": ["dist/**", "tsconfig.tsbuildinfo"],
      "env": [
        "MVP_DATABASE_URL",
        "MVP_S3_DOWNLOADS_BUCKET",
        "NODEJS_HELPERS",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_REGION"
      ]
    },
    "@renewable-energy/mvp-api#typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@renewable-energy/mvp-api#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": [
        "MVP_DATABASE_URL",
        "MVP_CORS_ORIGINS",
        "MVP_S3_DOWNLOADS_BUCKET",
        "NODEJS_HELPERS",
        "NODE_ENV",
        "PORT",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_REGION",
        "CLERK_SECRET_KEY"
      ]
    },
    "mvp-db:generate": {
      "inputs": ["prisma/**/*.prisma", "prisma.config.ts"],
      "outputs": ["node_modules/.prisma/**"],
      "cache": false
    },
    "mvp-db:validate": {
      "inputs": ["prisma/**/*.prisma", "prisma.config.ts"],
      "outputs": []
    },
    "mvp-db:status": {
      "dependsOn": ["mvp-db:generate"],
      "cache": false
    },
    "mvp-db:migrate": {
      "dependsOn": ["mvp-db:generate"],
      "cache": false
    },
    "mvp-db:studio": {
      "dependsOn": ["mvp-db:generate"],
      "persistent": true,
      "cache": false
    }
  }
}
