{
  "name": "@solarlayout/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "SolarLayout desktop app — Tauri 2 shell + React 19 frontend",
  "scripts": {
    "dev": "tauri dev",
    "build": "tsc --noEmit && vite build",
    "tauri": "tauri",
    "tauri:build": "bun run bundle:sidecar && tauri build",
    "vite:dev": "vite",
    "vite:build": "tsc --noEmit && vite build",
    "bundle:sidecar": "node scripts/bundle-sidecar.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@solarlayout/entitlements-client": "workspace:*",
    "@solarlayout/sidecar-client": "workspace:*",
    "@solarlayout/ui": "workspace:*",
    "@tanstack/react-query": "^5.62.11",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-fs": "^2.2.0",
    "@tauri-apps/plugin-http": "^2.2.0",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "maplibre-gl": "^4.7.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/geojson": "^7946.0.15",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.5"
  }
}
