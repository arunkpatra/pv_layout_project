{
  "name": "@solarlayout/mvp-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --env-file ../../.env --hot src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --external @prisma/client-runtime-utils --external @solarlayout/mvp-db",
    "vercel-build": "cd ../.. && bun turbo build --filter=@solarlayout/mvp-api",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@clerk/backend": "^1.0.0",
    "@hono/node-server": "^1.19.14",
    "@solarlayout/entitlements-client": "workspace:*",
    "@solarlayout/mvp-db": "workspace:*",
    "@solarlayout/shared": "workspace:*",
    "hono": "^4.12.0",
    "stripe": "^20.3.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@solarlayout/eslint-config": "workspace:*",
    "@solarlayout/typescript-config": "workspace:*",
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3"
  }
}
