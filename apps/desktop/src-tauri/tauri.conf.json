{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SolarLayout",
  "version": "0.0.0",
  "identifier": "in.solarlayout.desktop",
  "build": {
    "beforeDevCommand": "bun run vite:dev",
    "beforeBuildCommand": "bun run bundle:sidecar && bun run vite:build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SolarLayout",
        "width": 1440,
        "height": 900,
        "minWidth": 1040,
        "minHeight": 640,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "msi", "nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/pvlayout-engine"],
    "copyright": "",
    "category": "Utility",
    "shortDescription": "Solar PV plant layout design",
    "longDescription": "Native desktop application for automated solar PV plant layout design. Parses KMZ site boundaries and produces panel table layouts, inverter placement, cable routing, and KMZ/DXF/PDF exports."
  }
}
